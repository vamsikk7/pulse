# Auth is intentionally disabled for now — every request uses DEMO_USER_ID below.

# ---- Web ----
NEXT_PUBLIC_API_URL=http://localhost:4000
API_INTERNAL_URL=http://api:4000
NEXT_PUBLIC_DEBUG_MODE=true

# ---- API + Worker ----
PORT=4000
NODE_ENV=development
MONGO_URL=mongodb://mongo:27017/pulse
REDIS_URL=redis://redis:6379
DEMO_USER_ID=user_demo_seed

# ---- MinIO ----
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=petitions
MINIO_PUBLIC_URL=http://localhost:9000

# ---- Ollama (host machine) ----
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_KEEP_ALIVE=10m

# ---- Feature flags ----
DEBUG_MODE=true
USCIS_SCRAPE_ENABLED=true
USCIS_RATE_LIMIT_MS=10000

# ---- Security ----
CLAMAV_ENABLED=true
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=30000
UPLOAD_HOURLY_LIMIT=30
UPLOAD_DAILY_LIMIT=100
