{
  "name": "pulse",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up --build",
    "dev:down": "docker compose down",
    "dev:reset": "docker compose down -v",
    "logs": "docker compose logs -f",
    "seed": "npm -w apps/api run seed",
    "reseed": "npm -w apps/api run reseed",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "npm -ws --if-present run typecheck"
  },
  "devDependencies": {
    "pdfkit": "^0.15.2",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  }
}